ПРАВИЛА КАЛИБРОВКИ УВЕРЕННОСТИ:
- 90-99%: документировано несколькими независимыми источниками + первичные данные
- 70-89%: сходятся несколько источников, но есть нюансы
- 55-69%: основной нарратив держится, но детали разнятся
- 40-54%: только одна сторона, непроверено, или устаревшее

Не фальши-балансируй фактические вопросы («обе стороны правы»). Но разоблачай нарративный фрейминг со всех сторон. Лучше честные 65% с объяснением, чем ложные 95%.`;

const FraunBrand = () => (
  <span style={{ fontFamily: '"Fraunces", serif', fontVariationSettings: '"opsz" 144, "wght" 700, "SOFT" 50' }}>
    ТРИАНГУЛЯЦИЯ
  </span>
);

export default function App() {
  const [query, setQuery] = useState('');
  const [loading, setLoading] = useState(false);
  const [result, setResult] = useState(null);
  const [error, setError] = useState(null);
  const [raw, setRaw] = useState(null);
  const [showRaw, setShowRaw] = useState(false);
  const [elapsedStage, setElapsedStage] = useState(0);
  const intervalRef = useRef(null);

  useEffect(() => {
    // Inject fonts once
    if (!document.getElementById('trng-fonts')) {
      const link = document.createElement('link');
      link.id = 'trng-fonts';
      link.rel = 'stylesheet';
      link.href = 'https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT@9..144,300..900,0..100&family=Source+Serif+4:opsz,wght@8..60,300..700&family=JetBrains+Mono:wght@300;400;500;700&display=swap';
      document.head.appendChild(link);
    }
  }, []);

  useEffect(() => {
    if (loading) {
      setElapsedStage(0);
      intervalRef.current = setInterval(() => setElapsedStage(s => s + 1), 1000);
    } else {
      clearInterval(intervalRef.current);
    }
    return () => clearInterval(intervalRef.current);
  }, [loading]);

  const runAnalysis = async (topic) => {
    const t = (topic ?? query).trim();
    if (!t) return;
    setLoading(true);
    setError(null);
    setResult(null);
    setRaw(null);

    try {
      const response = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 8000,
          messages: [
            {
              role: "user",
              content: `${SYSTEM_PROMPT}\n\n=== ТЕМА ДЛЯ АНАЛИЗА ===\n${t}\n\nСделай поиски и верни JSON согласно схеме. Текущая дата: ${new Date().toISOString().slice(0,10)}.`
            }
          ],
          tools: [{ type: "web_search_20250305", name: "web_search" }]
        })
      });

      if (!response.ok) {
        const txt = await response.text();
        throw new Error(`API вернул ${response.status}: ${txt.slice(0,300)}`);
      }

      const data = await response.json();
      setRaw(data);

      const textPieces = data.content
        .filter(b => b.type === 'text')
        .map(b => b.text)
        .join('\n');

      const cleaned = textPieces.replace(/```json|```/g, '').trim();
      const firstBrace = cleaned.indexOf('{');
      const lastBrace  = cleaned.lastIndexOf('}');
      if (firstBrace === -1 || lastBrace === -1) {
        throw new Error('Не удалось найти JSON в ответе модели.');
      }
      const parsed = JSON.parse(cleaned.slice(firstBrace, lastBrace + 1));
      setResult(parsed);
    } catch (e) {
      setError(e.message || String(e));
    } finally {
      setLoading(false);
    }
  };

  // ============================================================
  //  RENDER
  // ============================================================

  return (
    <div style={{
      background: '#F4EFE4',
      color: '#1A1815',
      minHeight: '100vh',
      fontFamily: '"Source Serif 4", Georgia, serif',
      backgroundImage: `
        radial-gradient(rgba(26,24,21,0.04) 1px, transparent 1px),
        radial-gradient(rgba(26,24,21,0.02) 1px, transparent 1px)
      `,
      backgroundSize: '3px 3px, 11px 11px',
      backgroundPosition: '0 0, 1px 1px',
    }}>
      <style>{`
        .trng-serif { font-family: "Source Serif 4", Georgia, serif; }
        .trng-display { font-family: "Fraunces", serif; font-variation-settings: "opsz" 144, "wght" 600, "SOFT" 50; letter-spacing: -0.01em; }
        .trng-mono { font-family: "JetBrains Mono", ui-monospace, monospace; font-feature-settings: "ss02", "zero"; }
        .trng-caps { font-family: "JetBrains Mono", ui-monospace, monospace; text-transform: uppercase; letter-spacing: 0.18em; font-weight: 500; }
        .trng-rule { border-top: 1px solid #1A1815; }
        .trng-rule-thin { border-top: 0.5px solid rgba(26,24,21,0.35); }
        .trng-rule-dbl { border-top: 3px double #1A1815; }
        @keyframes trng-pulse { 0%,100% { opacity: 0.4; } 50% { opacity: 1; } }
        .trng-pulse { animation: trng-pulse 1.4s ease-in-out infinite; }
        @keyframes trng-fadeUp { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
        .trng-fadeUp { animation: trng-fadeUp 0.5s ease-out both; }
        .trng-input {
          background: transparent; border: none; outline: none;
          width: 100%; font-family: "Fraunces", serif;
          font-variation-settings: "opsz" 60, "wght" 400;
          color: #1A1815; font-size: 1.5rem; padding: 0.5rem 0;
        }
        .trng-input::placeholder { color: rgba(26,24,21,0.35); font-style: italic; }
        .trng-chip {
          font-family: "JetBrains Mono", monospace; font-size: 11px;
          letter-spacing: 0.08em; padding: 4px 10px;
          border: 1px solid rgba(26,24,21,0.35); cursor: pointer;
          transition: all 150ms ease; background: transparent; color: #1A1815;
        }
        .trng-chip:hover { background: #1A1815; color: #F4EFE4; }
        .trng-btn {
          font-family: "JetBrains Mono", monospace; font-size: 12px;
          letter-spacing: 0.2em; text-transform: uppercase;
          padding: 12px 24px; background: #1A1815; color: #F4EFE4;
          border: none; cursor: pointer; transition: all 180ms ease;
        }
        .trng-btn:hover:not(:disabled) { background: #A63D2A; }
        .trng-btn:disabled { opacity: 0.5; cursor: wait; }
      `}</style>

      <div style={{ maxWidth: '1180px', margin: '0 auto', padding: '32px 28px 80px' }}>

        {/* ========== MASTHEAD ========== */}
        <header>
          <div className="trng-caps" style={{ fontSize: '10px', display: 'flex', justifyContent: 'space-between', opacity: 0.65 }}>
            <span>vol. 1 · личный компрессор новостей</span>
            <span>{new Date().toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' }).toUpperCase()}</span>
          </div>
          <div className="trng-rule" style={{ marginTop: 6 }} />
          <div style={{ textAlign: 'center', padding: '28px 0 20px' }}>
            <h1 className="trng-display" style={{ fontSize: 'clamp(48px, 7vw, 92px)', margin: 0, lineHeight: 0.95 }}>
              <FraunBrand />
            </h1>
            <div className="trng-caps" style={{ fontSize: '10px', marginTop: '12px', opacity: 0.7 }}>
              три+ независимых источника · доверительные интервалы · без эмоциональных искажений
            </div>
          </div>
          <div className="trng-rule-dbl" />
        </header>

        {/* ========== INPUT PANEL ========== */}
        {!result && !loading && (
          <section style={{ padding: '48px 0 24px' }}>
            <div className="trng-caps" style={{ fontSize: '11px', opacity: 0.65, marginBottom: 8 }}>
              запрос · тема или событие
            </div>
            <input
              className="trng-input"
              value={query}
              onChange={(e) => setQuery(e.target.value)}
              onKeyDown={(e) => e.key === 'Enter' && runAnalysis()}
              placeholder="напр. «Забой коров на Мираторге — что реально происходит»"
              autoFocus
            />
            <div className="trng-rule-thin" />
            <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginTop: 20, flexWrap: 'wrap', gap: 16 }}>
              <div style={{ display: 'flex', gap: 8, flexWrap: 'wrap' }}>
                {EXAMPLES.map((ex, i) => (
                  <button key={i} className="trng-chip" onClick={() => { setQuery(ex); runAnalysis(ex); }}>
                    {ex}
                  </button>
                ))}
              </div>
              <button className="trng-btn" onClick={() => runAnalysis()} disabled={!query.trim()}>
                Триангулировать →
              </button>
            </div>

            {/* Methodology note */}
            <div style={{ marginTop: 64, display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(220px, 1fr))', gap: 32 }}>
              {[
                { n: '01', t: 'Поиск с разных углов', d: 'Западный мейнстрим, российские, китайские, отраслевые, первичные — намеренно диверсифицированный пул.' },
                { n: '02', t: 'Пересечение фактов', d: 'Отделяем задокументированное от интерпретации. Каждое утверждение получает процент уверенности.' },
                { n: '03', t: 'Разбор акторов', d: 'Кто действует, кому что выгодно, насколько им стоит доверять именно в этом сюжете.' },
                { n: '04', t: 'Флаги манипуляции', d: 'Эмоциональные апелляции, выпущенный контекст, единичный случай как система — подсвечиваем приёмы.' },
              ].map(b => (
                <div key={b.n}>
                  <div className="trng-mono" style={{ fontSize: 11, opacity: 0.5 }}>{b.n}</div>
                  <div className="trng-display" style={{ fontSize: 20, marginTop: 4, fontVariationSettings: '"opsz" 60, "wght" 500' }}>{b.t}</div>
                  <div style={{ fontSize: 14, marginTop: 6, lineHeight: 1.5, opacity: 0.78 }}>{b.d}</div>
                </div>
              ))}
            </div>
          </section>
        )}

        {/* ========== LOADING ========== */}
        {loading && (
          <section style={{ padding: '80px 0', textAlign: 'center' }}>
            <div className="trng-caps trng-pulse" style={{ fontSize: 11 }}>
              триангуляция в процессе
            </div>
            <div className="trng-display" style={{ fontSize: 28, marginTop: 18, fontVariationSettings: '"opsz" 60, "wght" 400', fontStyle: 'italic', opacity: 0.85 }}>
              «{query}»
            </div>
            <div className="trng-rule-thin" style={{ margin: '32px auto', maxWidth: 360 }} />
            <div className="trng-mono" style={{ fontSize: 12, opacity: 0.6, lineHeight: 2 }}>
              <div>→ запрашиваем западный мейнстрим</div>
              {elapsedStage > 3 && <div className="trng-fadeUp">→ запрашиваем российские источники</div>}
              {elapsedStage > 7 && <div className="trng-fadeUp">→ запрашиваем первичные и отраслевые</div>}
              {elapsedStage > 12 && <div className="trng-fadeUp">→ перекрёстная проверка</div>}
              {elapsedStage > 18 && <div className="trng-fadeUp">→ разбор акторов и фрейминга</div>}
              {elapsedStage > 25 && <div className="trng-fadeUp" style={{ opacity: 0.5 }}>→ собираем отчёт (обычно ~30-60с)</div>}
            </div>
            <div className="trng-mono" style={{ fontSize: 10, opacity: 0.4, marginTop: 40 }}>
              t+{elapsedStage}s
            </div>
          </section>
        )}

        {/* ========== ERROR ========== */}
        {error && !loading && (
          <section style={{ padding: '40px 0' }}>
            <div className="trng-caps" style={{ fontSize: 11, color: '#A63D2A' }}>ошибка</div>
            <div className="trng-rule-thin" style={{ margin: '8px 0 16px', borderColor: '#A63D2A' }} />
            <div className="trng-mono" style={{ fontSize: 13, whiteSpace: 'pre-wrap', lineHeight: 1.6 }}>{error}</div>
            <button className="trng-btn" style={{ marginTop: 24 }} onClick={() => { setError(null); setResult(null); }}>
              Новый запрос
            </button>
          </section>
        )}

        {/* ========== RESULTS ========== */}
        {result && !loading && (
          <ResultView
            result={result}
            query={query}
            onReset={() => { setResult(null); setQuery(''); setRaw(null); }}
            raw={raw}
            showRaw={showRaw}
            setShowRaw={setShowRaw}
          />
        )}

        <footer style={{ marginTop: 80 }}>
          <div className="trng-rule-dbl" />
          <div className="trng-caps" style={{ fontSize: 10, opacity: 0.5, marginTop: 12, display: 'flex', justifyContent: 'space-between', flexWrap: 'wrap', gap: 12 }}>
            <span>модель не всевидяща · всегда читай первоисточники по важным решениям</span>
            <span>powered by claude + web search</span>
          </div>
        </footer>
      </div>
    </div>
  );
}

