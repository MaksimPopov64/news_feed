function ResultView({ result, query, onReset, raw, showRaw, setShowRaw }) {
  const {
    headline, context, established = [], contested = [],
    actors = [], framings = [], manipulation_flags = [],
    bottom_line, open_questions = [], action_guidance
  } = result;

  return (
    <article className="trng-fadeUp" style={{ paddingTop: 32 }}>
      {/* Topline bar */}
      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', flexWrap: 'wrap', gap: 12, marginBottom: 16 }}>
        <div className="trng-caps" style={{ fontSize: 10, opacity: 0.65 }}>
          досье № {Math.floor(Math.random() * 9000 + 1000)} · запрос: «{query}»
        </div>
        <div style={{ display: 'flex', gap: 8 }}>
          <button className="trng-chip" onClick={() => setShowRaw(!showRaw)}>
            {showRaw ? 'скрыть raw' : 'raw json'}
          </button>
          <button className="trng-chip" onClick={onReset}>← новый запрос</button>
        </div>
      </div>

      {/* Headline */}
      <h2 className="trng-display" style={{
        fontSize: 'clamp(28px, 4.2vw, 48px)',
        lineHeight: 1.1,
        margin: 0,
        fontVariationSettings: '"opsz" 144, "wght" 500',
      }}>
        {headline}
      </h2>

      {context && (
        <>
          <div className="trng-rule-thin" style={{ margin: '20px 0 14px' }} />
          <div style={{ fontSize: 17, lineHeight: 1.55, fontStyle: 'italic', opacity: 0.85, maxWidth: 820 }}>
            {context}
          </div>
        </>
      )}

      {/* ========== BOTTOM LINE (moved up for scan-first reading) ========== */}
      {bottom_line && (
        <div style={{ margin: '40px 0', padding: '28px 32px', background: '#1A1815', color: '#F4EFE4', position: 'relative' }}>
          <div className="trng-caps" style={{ fontSize: 10, opacity: 0.7 }}>итог</div>
          <div className="trng-display" style={{
            fontSize: 'clamp(20px, 2.4vw, 26px)',
            lineHeight: 1.35,
            marginTop: 10,
            fontVariationSettings: '"opsz" 60, "wght" 400',
          }}>
            {bottom_line}
          </div>
          {action_guidance && (
            <>
              <div style={{ borderTop: '1px solid rgba(244,239,228,0.25)', margin: '20px 0 14px' }} />
              <div className="trng-caps" style={{ fontSize: 10, opacity: 0.7 }}>если принимаешь решение</div>
              <div style={{ fontSize: 15, lineHeight: 1.55, marginTop: 8, opacity: 0.95 }}>
                {action_guidance}
              </div>
            </>
          )}
        </div>
      )}

      {/* ========== ESTABLISHED & CONTESTED (2-col) ========== */}
      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(340px, 1fr))', gap: 40, marginTop: 48 }}>
        {/* Established */}
        <div>
          <SectionHead num="I" label="Установленные факты" sub={`${established.length} утв.`} />
          <ul style={{ listStyle: 'none', padding: 0, margin: 0 }}>
            {established.map((e, i) => (
              <li key={i} style={{ padding: '18px 0', borderBottom: '0.5px solid rgba(26,24,21,0.2)' }}>
                <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'baseline', gap: 12, marginBottom: 8 }}>
                  <span className="trng-mono" style={{ fontSize: 11, opacity: 0.5 }}>{String(i+1).padStart(2, '0')}</span>
                  <ConfidenceMeter value={e.confidence} />
                </div>
                <div style={{ fontSize: 15.5, lineHeight: 1.5 }}>{e.claim}</div>
                <div style={{ marginTop: 10, display: 'flex', gap: 6, flexWrap: 'wrap', alignItems: 'center' }}>
                  <span className="trng-mono" style={{ fontSize: 10, opacity: 0.55 }}>
                    n={e.sources_count ?? '—'}
                  </span>
                  {(e.source_types || []).map((st, j) => <ClusterTag key={j} cluster={st} />)}
                </div>
              </li>
            ))}
            {established.length === 0 && <EmptyRow text="Нет твёрдо установленных фактов." />}
          </ul>
        </div>

        {/* Contested */}
        <div>
          <SectionHead num="II" label="Оспариваемое" sub={`${contested.length} спор.`} />
          <ul style={{ listStyle: 'none', padding: 0, margin: 0 }}>
            {contested.map((c, i) => (
              <li key={i} style={{ padding: '18px 0', borderBottom: '0.5px solid rgba(26,24,21,0.2)' }}>
                <div className="trng-mono" style={{ fontSize: 11, opacity: 0.5, marginBottom: 6 }}>
                  {String(i+1).padStart(2, '0')}
                </div>
                <div className="trng-display" style={{ fontSize: 18, fontVariationSettings: '"opsz" 60, "wght" 500', marginBottom: 12 }}>
                  {c.claim}
                </div>
                {(c.versions || []).map((v, j) => (
                  <div key={j} style={{ marginTop: 10, paddingLeft: 14, borderLeft: `3px solid ${CLUSTER_META[v.cluster]?.ink || '#888'}` }}>
                    <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'baseline', gap: 8, flexWrap: 'wrap' }}>
                      <ClusterTag cluster={v.cluster} />
                      <span className="trng-mono" style={{ fontSize: 10, opacity: 0.65 }}>
                        правдоподобие {v.plausibility}%
                      </span>
                    </div>
                    <div style={{ fontSize: 14, lineHeight: 1.5, marginTop: 6 }}>
                      <span style={{ opacity: 0.55 }}>{v.who_says}:</span> {v.view}
                    </div>
                  </div>
                ))}
              </li>
            ))}
            {contested.length === 0 && <EmptyRow text="Версии не расходятся существенно." />}
          </ul>
        </div>
      </div>

      {/* ========== ACTORS ========== */}
      {actors.length > 0 && (
        <div style={{ marginTop: 64 }}>
          <SectionHead num="III" label="Действующие лица и интересы" sub={`${actors.length}`} />
          <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(280px, 1fr))', gap: 24 }}>
            {actors.map((a, i) => (
              <div key={i} style={{ padding: '20px 22px', background: 'rgba(26,24,21,0.04)', border: '0.5px solid rgba(26,24,21,0.2)' }}>
                <div className="trng-display" style={{ fontSize: 20, fontVariationSettings: '"opsz" 60, "wght" 600' }}>
                  {a.name}
                </div>
                <div style={{ fontSize: 13, fontStyle: 'italic', opacity: 0.7, marginTop: 2 }}>{a.role}</div>
                <div className="trng-rule-thin" style={{ margin: '12px 0' }} />
                <div style={{ fontSize: 13, lineHeight: 1.5 }}>
                  <span className="trng-caps" style={{ fontSize: 9, opacity: 0.65 }}>интересы → </span>
                  {a.interests}
                </div>
                <div style={{ fontSize: 13, lineHeight: 1.5, marginTop: 10 }}>
                  <span className="trng-caps" style={{ fontSize: 9, opacity: 0.65 }}>доверие → </span>
                  {a.reliability}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* ========== FRAMINGS ========== */}
      {framings.length > 0 && (
        <div style={{ marginTop: 64 }}>
          <SectionHead num="IV" label="Как подают разные источники" sub="фрейминг-анализ" />
          <div style={{ display: 'flex', flexDirection: 'column' }}>
            {framings.map((f, i) => (
              <div key={i} style={{
                display: 'grid',
                gridTemplateColumns: '160px 1fr',
                gap: 24,
                padding: '22px 0',
                borderTop: i === 0 ? '1px solid #1A1815' : '0.5px solid rgba(26,24,21,0.2)',
              }}>
                <div>
                  <ClusterTag cluster={f.cluster} big />
                </div>
                <div>
                  <div style={{ fontSize: 15.5, lineHeight: 1.5, marginBottom: 14 }}>
                    {f.narrative}
                  </div>
                  <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(220px, 1fr))', gap: 18, fontSize: 13, lineHeight: 1.5 }}>
                    <div>
                      <div className="trng-caps" style={{ fontSize: 9, opacity: 0.6, marginBottom: 4 }}>подчёркивают</div>
                      <div>{f.emphasis}</div>
                    </div>
                    <div>
                      <div className="trng-caps" style={{ fontSize: 9, color: '#A63D2A', marginBottom: 4 }}>умалчивают</div>
                      <div style={{ opacity: 0.85 }}>{f.omissions}</div>
                    </div>
                  </div>
                </div>
              </div>
            ))}
            <div className="trng-rule" />
          </div>
        </div>
      )}

      {/* ========== MANIPULATION FLAGS ========== */}
      {manipulation_flags.length > 0 && (
        <div style={{ marginTop: 64 }}>
          <SectionHead num="V" label="Флаги манипуляции" sub={`${manipulation_flags.length} шт.`} accent />
          <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(300px, 1fr))', gap: 16 }}>
            {manipulation_flags.map((m, i) => (
              <div key={i} style={{
                padding: '18px 20px',
                border: `1px solid #A63D2A`,
                background: 'rgba(166,61,42,0.04)',
                position: 'relative',
              }}>
                <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'baseline', gap: 8 }}>
                  <div className="trng-caps" style={{ fontSize: 10, color: '#A63D2A' }}>
                    ⚑ {FLAG_LABELS[m.type] || m.type}
                  </div>
                  <span className="trng-mono" style={{ fontSize: 10, opacity: 0.6 }}>
                    sev {m.severity || '—'}/5
                  </span>
                </div>
                <div style={{ fontSize: 14, lineHeight: 1.5, marginTop: 8 }}>{m.description}</div>
                {m.example && (
                  <div style={{ fontSize: 12.5, lineHeight: 1.5, marginTop: 10, padding: '8px 12px', background: 'rgba(26,24,21,0.06)', borderLeft: '2px solid #A63D2A', fontStyle: 'italic' }}>
                    «{m.example}»
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      )}

      {/* ========== OPEN QUESTIONS ========== */}
      {open_questions.length > 0 && (
        <div style={{ marginTop: 64 }}>
          <SectionHead num="VI" label="Открытые вопросы" sub="что ещё неясно" />
          <ul style={{ listStyle: 'none', padding: 0, margin: 0 }}>
            {open_questions.map((q, i) => (
              <li key={i} style={{
                display: 'flex', gap: 16, padding: '14px 0',
                borderBottom: '0.5px solid rgba(26,24,21,0.2)',
              }}>
                <span className="trng-mono" style={{ fontSize: 11, opacity: 0.45, flexShrink: 0, width: 24 }}>
                  ?.{String(i+1).padStart(2, '0')}
                </span>
                <span style={{ fontSize: 15, lineHeight: 1.5, fontStyle: 'italic' }}>{q}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      {/* ========== RAW JSON ========== */}
      {showRaw && (
        <div style={{ marginTop: 48, padding: 20, background: '#1A1815', color: '#F4EFE4' }}>
          <div className="trng-caps" style={{ fontSize: 10, opacity: 0.6, marginBottom: 10 }}>raw response</div>
          <pre className="trng-mono" style={{ fontSize: 11, lineHeight: 1.5, overflow: 'auto', maxHeight: 400 }}>
            {JSON.stringify(result, null, 2)}
          </pre>
        </div>
      )}
    </article>
  );
}

// ============================================================
//  SUBCOMPONENTS
// ============================================================
function SectionHead({ num, label, sub, accent }) {
  return (
    <>
      <div style={{ display: 'flex', alignItems: 'baseline', gap: 14, marginBottom: 14 }}>
        <span className="trng-display" style={{
          fontSize: 28,
          fontVariationSettings: '"opsz" 144, "wght" 300',
          color: accent ? '#A63D2A' : '#1A1815',
          fontStyle: 'italic',
        }}>
          {num}
        </span>
        <span className="trng-caps" style={{ fontSize: 11, color: accent ? '#A63D2A' : '#1A1815' }}>
          {label}
        </span>
        {sub && <span className="trng-mono" style={{ fontSize: 11, opacity: 0.5, marginLeft: 'auto' }}>{sub}</span>}
      </div>
      <div className="trng-rule" style={{ borderColor: accent ? '#A63D2A' : '#1A1815', marginBottom: 14 }} />
    </>
  );
}

function ClusterTag({ cluster, big }) {
  const m = CLUSTER_META[cluster] || CLUSTER_META.other;
  return (
    <span className="trng-caps" style={{
      fontSize: big ? 11 : 9,
      color: m.ink,
      border: `1px solid ${m.ink}`,
      padding: big ? '4px 10px' : '2px 7px',
      background: 'transparent',
      display: 'inline-block',
    }}>
      {big ? m.label : m.short}
    </span>
  );
}

function ConfidenceMeter({ value }) {
  const v = Math.max(0, Math.min(100, value ?? 0));
  const color = v >= 85 ? '#3B5E3C' : v >= 65 ? '#1A1815' : v >= 50 ? '#A66A1F' : '#A63D2A';
  return (
    <div style={{ display: 'flex', alignItems: 'center', gap: 8, flexShrink: 0 }}>
      <div style={{ width: 80, height: 4, background: 'rgba(26,24,21,0.12)', position: 'relative' }}>
        <div style={{ width: `${v}%`, height: '100%', background: color }} />
      </div>
      <span className="trng-mono" style={{ fontSize: 11, fontWeight: 500, color, minWidth: 30, textAlign: 'right' }}>
        {v}%
      </span>
    </div>
  );
}

function EmptyRow({ text }) {
  return <li style={{ padding: '18px 0', fontSize: 14, fontStyle: 'italic', opacity: 0.5 }}>{text}</li>;
}
